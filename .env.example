# =============================================================================
# Ouwibo Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (Groq)
# -----------------------------------------------------------------------------
# Primary API Key
API_KEY=your_primary_gsk_api_key_here

# Fallback API Key (Optional but recommended)
GROQ_API_KEY2=your_fallback_gsk_api_key_here

# -----------------------------------------------------------------------------
# Security (optional)
# -----------------------------------------------------------------------------
# Static Bearer token for API protection.
# If NOT set, auth is disabled (development mode).
# Example: ACCESS_TOKEN=my-secure-secret-token
# -----------------------------------------------------------------------------
# ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# CORS Origins (optional)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins.
# Default: * (allow all — development only)
# Example: https://yourdomain.com,https://www.yourdomain.com
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=*
