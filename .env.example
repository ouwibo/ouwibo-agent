# =============================================================================
# Ouwibo Agent — Environment Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── AI Provider: Alibaba Cloud (DashScope) ───────────────────────────────────
# Obtain API key at: https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ── Protocol & Integrations ──────────────────────────────────────────────────
# Virtuals Protocol API Key
# Generate at: https://app.virtuals.io/settings/api-keys
VIRTUALS_API_KEY=your_virtuals_api_key_here

# ── Server Configuration ─────────────────────────────────────────────────────
# Local port for the FastAPI server
PORT=8001

# Allowed origins for CORS (comma-separated, default: *)
ALLOWED_ORIGINS=*

# ── Security & Authentication ────────────────────────────────────────────────
# Shared secret for BEARER authentication (optional)
# Example: my-secure-token
# ACCESS_TOKEN=

# ── Search Configuration ─────────────────────────────────────────────────────
# Search provider for WebSearch tool (auto, ddgs, google)
SEARCH_PROVIDER=auto
