# Ouwibo Agent — Environment Configuration
# Copy this file to .env and fill in your keys

# Alibaba Cloud DashScope API Key
# Get one at: https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Access Token (optional, for locking the API/UI)
# If not set, authentication will be disabled.
ACCESS_TOKEN=your_secret_access_token_here

# Search Provider (optional: auto, duckduckgo, google)
SEARCH_PROVIDER=auto

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Server Port (default: 8001)
PORT=8001
