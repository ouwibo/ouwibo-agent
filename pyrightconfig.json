{
  "venvPath": ".",
  "venv": "backend/venv",
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic",
  "executionEnvironments": [
    {
      "root": "backend",
      "extraPaths": ["."]
    }
  ],
  "include": ["backend"],
  "exclude": ["**/__pycache__", "**/node_modules", "**/venv", "static", "scripts"],
  "stubPath": "typings"
}
