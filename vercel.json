{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/backend/static/$1"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "."
}
