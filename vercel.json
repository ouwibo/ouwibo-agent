{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "backend/static/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/auth/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/((?!api|auth).*)",
      "destination": "/backend/static/$1"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "."
}
