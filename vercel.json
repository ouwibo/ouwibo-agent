{
  "version": 2,
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api.py"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api.py"
    },
    {
      "source": "/(.*)",
      "destination": "/static/$1"
    }
  ]
}
