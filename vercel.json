{
  "version": 2,
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "api.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*).(js|css|png|jpg|svg|html)",
      "dest": "/static/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/static/index.html"
    }
  ]
}
