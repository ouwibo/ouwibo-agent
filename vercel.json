{
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/((?!api|auth).*)",
      "destination": "/backend/static/$1"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "."
}
